# Application
ENVIRONMENT=production
SECRET_KEY=change-this-to-a-secure-random-string-min-32-chars
DEBUG=false

# Redis
REDIS_URL=redis://:redis@localhost:6379/0
REDIS_PASSWORD=redis

# Auth
JWT_SECRET=change-this-jwt-secret
JWT_EXPIRY_HOURS=24

